# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore

# ------------------------------
# Go binaries and build outputs
# ------------------------------
*.exe
*.exe~
*.dll
*.so
*.dylib
*.a

# Common local build folders
bin/
dist/
tmp/

# Test binary, built with go test -c
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Go workspace file
go.work
go.work.sum

# ------------------------------
# Frontend (Node.js / Vite)
# ------------------------------
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/.cache/

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ------------------------------
# Environment and local config
# ------------------------------
.env
.env.*
!.env.example
backend/config.yaml
backend/config.local.yaml
!backend/config.example.yaml

# Local runtime data / sqlite / logs
*.db
*.sqlite
*.sqlite3
*.log

# ------------------------------
# Editor / IDE
# ------------------------------
.idea/
.vscode/*
!.vscode/tasks.json
!.vscode/settings.json
!.vscode/extensions.json

# ------------------------------
# OS generated files
# ------------------------------
.DS_Store
Thumbs.db
desktop.ini
.vscode
plan.md
allplan.md
*.md